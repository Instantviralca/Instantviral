{
  "name": "instantviral-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:sql": "npx tsx scripts/apply-migrations.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx scripts/seed-dev.ts",
    "env:verify": "npx tsx scripts/verify-production-env.ts",
    "create-article": "./scripts/create-article.sh",
    "content:refresh-assets": "SCAFFOLD_CONTENT_ASSETS=1 npx vitest run lib/content-generators/__tests__/refresh-assets.test.ts",
    "content:qa": "SCAFFOLD_CONTENT_QA=1 npx vitest run lib/content-qa/__tests__/content-qa.test.ts",
    "content:library-sync": "SCAFFOLD_CONTENT_LIBRARY=1 npx vitest run lib/content-library/__tests__/content-library.test.ts",
    "content:apply-article-01": "APPLY_ARTICLE_01=1 npx vitest run lib/content-library/__tests__/apply-article-01.test.ts",
    "content:analytics-report": "SCAFFOLD_CONTENT_ANALYTICS_REPORT=1 npx vitest run lib/content-analytics/__tests__/content-analytics.test.ts"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.23.12",
    "geist": "^1.7.2",
    "lucide-react": "^0.525.0",
    "next": "^15.5.7",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.3.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
