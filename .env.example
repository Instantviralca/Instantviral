# Environment placeholders (fill in for local/production)
# Never commit .env.local
# Full runbook: DEPLOYMENT.md

# ── Site (HTTPS required in production) ───────────────
# NEXT_PUBLIC_SITE_URL=https://instantviral.ca
# SITE_URL=https://instantviral.ca

# Dedicated checkout subdomain (same Next.js app — Vercel domain alias)
# NEXT_PUBLIC_CHECKOUT_URL=https://checkout.instantviral.ca
# Local fallback (omit): checkout uses /checkout on the main origin
# Dev force checkout-host middleware: append ?checkoutHost=1

# ── Database (PostgreSQL / Neon / Supabase) ───────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# Dev-only file store fallback (never in production)
# IV_ALLOW_FILE_STORE=1

# Force in-memory persistence (tests)
# IV_PERSISTENCE=memory

# ── Admin auth ────────────────────────────────────────
# Prefer strong unique values in production (aliases: ADMIN_PASSWORD, SESSION_SECRET)
# IV_ADMIN_PASSWORD=
# IV_ADMIN_SESSION_SECRET=
# IV_SHARED_SECRET=
# NEXT_PUBLIC_ADMIN_AUTH_CONFIGURED=true

# ── Remote payment (Admin → Settings preferred) ───────
# REMOTE_PAYMENT_WEBSITE_URL=https://your-payment-collector.com
# Local mock payments (non-production only):
# IV_PAYMENTS_MODE=mock

# ── Email (Resend) ────────────────────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=orders@your-verified-domain.com
# RESEND_FROM_EMAIL=orders@your-verified-domain.com   # alias for EMAIL_FROM
# EMAIL_SUPPORT=support@your-verified-domain.com
# EMAIL_ADMIN_TO=ops@your-verified-domain.com
# EMAIL_COMPANY_NAME=InstantViral

# ── Analytics — Document 14.09 ────────────────────────
# NEXT_PUBLIC_ANALYTICS_ENABLED=true
# NEXT_PUBLIC_ANALYTICS_DEBUG=false
# NEXT_PUBLIC_ANALYTICS_CONSENT_MODE=required
# NEXT_PUBLIC_GA4_ENABLED=false
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# NEXT_PUBLIC_GTM_ENABLED=false
# NEXT_PUBLIC_GTM_CONTAINER_ID=
# NEXT_PUBLIC_CLARITY_ENABLED=false
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Learn article preview (authorized editors only — Document 15.02)
# LEARN_ARTICLE_PREVIEW_SECRET=

# Skip production env throw during instrumentation (CI / build only)
# IV_SKIP_ENV_GUARD=1
