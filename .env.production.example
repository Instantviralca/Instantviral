# InstantViral — Production Environment Template
# =============================================================================
# Copy values into Vercel → Settings → Environment Variables (Production).
# NEVER commit a file that contains real secrets.
#
# Full guide: docs/PRODUCTION_DEPLOYMENT_GUIDE.md
# Verify locally (with secrets loaded, not committed):
#   IV_VERIFY_AS_PRODUCTION=1 npm run env:verify
# =============================================================================

# ── Site (required) ──────────────────────────────────────────────────────────
# Public HTTPS origin — used for payment return URLs, emails, absolute URLs.
# Obtain: your production domain
NEXT_PUBLIC_SITE_URL=https://instantviral.ca

# Dedicated checkout subdomain (same Vercel project — add domain + DNS CNAME)
# Obtain: configure checkout.instantviral.ca in Vercel Domains
NEXT_PUBLIC_CHECKOUT_URL=https://checkout.instantviral.ca

# ── Database (required) ──────────────────────────────────────────────────────
# PostgreSQL connection for orders, contacts, sessions, webhooks, site settings.
# Obtain: Neon / Supabase / managed Postgres → Connection string
# Example format (replace with real credentials):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=

# Optional fallback for remote payment collector URL (Admin → Settings can override)
# REMOTE_PAYMENT_WEBSITE_URL=https://your-payment-collector.com

# ── Admin auth (required) ────────────────────────────────────────────────────
# Obtain: generate yourself — do NOT use change-me-admin or other defaults
#   openssl rand -base64 32
IV_ADMIN_PASSWORD=

# Obtain: generate a random 64+ character secret
#   openssl rand -hex 64
IV_ADMIN_SESSION_SECRET=

# Optional public flag so the UI knows admin login is configured
NEXT_PUBLIC_ADMIN_AUTH_CONFIGURED=true

# ── Email / Resend (required) ────────────────────────────────────────────────
# Obtain: Resend Dashboard → API Keys
RESEND_API_KEY=

# Obtain: address on a domain verified in Resend → Domains
# Example: orders@instantviral.ca
EMAIL_FROM=

# Strongly recommended
EMAIL_ADMIN_TO=
EMAIL_SUPPORT=
EMAIL_COMPANY_NAME=InstantViral

# ── Do NOT set in production ─────────────────────────────────────────────────
# IV_PAYMENTS_MODE=mock
# IV_ALLOW_FILE_STORE=1
# IV_SKIP_ENV_GUARD=1
# IV_PERSISTENCE=memory

# ── Optional analytics (Document 14.09) ───────────────────────────────────────
# NEXT_PUBLIC_ANALYTICS_ENABLED=true
# NEXT_PUBLIC_ANALYTICS_DEBUG=false
# NEXT_PUBLIC_ANALYTICS_CONSENT_MODE=required
# NEXT_PUBLIC_GA4_ENABLED=false
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# NEXT_PUBLIC_GTM_ENABLED=false
# NEXT_PUBLIC_GTM_CONTAINER_ID=
# NEXT_PUBLIC_CLARITY_ENABLED=false
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# ── Optional Learn preview ───────────────────────────────────────────────────
# LEARN_ARTICLE_PREVIEW_SECRET=
